# ============================================================
# LuraUI — .gitignore
# ============================================================

# ─── Dependencies ────────────────────────────────────────────
node_modules/

# ─── Build Output ────────────────────────────────────────────
packages/frontend/dist/
packages/shared/dist/
*.tsbuildinfo

# ─── Database & Data (CONTAINS API KEYS!) ────────────────────
packages/backend/data/
*.db
*.db-journal
*.db-wal
*.db-shm

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.local
.env.*.local

# ─── OS & Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
